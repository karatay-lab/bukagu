# Template rendered by .github/workflows/release.yml into the Homebrew tap.
# Placeholders (@VERSION@, @TAG@, @AMD_SHA@, @ARM_SHA@) are filled from the
# release's musl tarball checksums. Linux-only (the release ships Linux builds).
class Bukagu < Formula
  desc "Swiss Army knife CLI for developers — file management and folder syncing"
  homepage "https://github.com/karatay-lab/bukagu"
  version "@VERSION@"
  license any_of: ["MIT", "Apache-2.0"]

  on_linux do
    on_arm do
      url "https://github.com/karatay-lab/bukagu/releases/download/@TAG@/bukagu-@TAG@-aarch64-unknown-linux-musl.tar.gz"
      sha256 "@ARM_SHA@"
    end
    on_intel do
      url "https://github.com/karatay-lab/bukagu/releases/download/@TAG@/bukagu-@TAG@-x86_64-unknown-linux-musl.tar.gz"
      sha256 "@AMD_SHA@"
    end
  end

  def install
    bin.install "bukagu"
  end

  test do
    assert_match "bukagu", shell_output("#{bin}/bukagu --version")
  end
end
