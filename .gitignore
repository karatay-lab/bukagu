# Rust / Cargo build artifacts
/target/

# Backup files from older rustfmt
**/*.rs.bk

# MSVC debug info
*.pdb

# Editor / OS noise
*.swp
*~
.DS_Store

# Claude Code local config / tooling — not tracked in the repo
.claude/
CLAUDE.md

# Local docs / working notes — not tracked in the repo
docs/
playground/

# Local bukagu store — machine-specific source/destination paths, created at runtime
/.bukagu/

# Local environment file — may hold the API token (BUKAGU_API_TOKEN); never commit it.
# A committed `.env.example` (no real secrets) is allowed.
.env
.env.*
!.env.example

# Note: Cargo.lock is intentionally committed — bukagu is a binary, not a library.
