# bukagu — example environment file.
# Copy to `.env` (gitignored) and fill in real values, or `export` these yourself.
# A real exported variable always overrides the value here.
#
# These feed the v3 encrypted-backup feature (`bukagu backup` / `auth status`).
# Prefer `bukagu auth login`, which stores them in ~/.config/bukagu/credentials.json
# (chmod 600); use `.env` only for local development convenience.

# Base URL of your key API (https:// required). bukagu calls GET {URL}/recipient.
BUKAGU_API_URL=https://your-api.example.com

# Bearer token copied from your website. Keep this out of version control.
BUKAGU_API_TOKEN=replace-me

# Optional: path appended to BUKAGU_API_URL to fetch the recipient key.
# Defaults to /recipient; override only if your API serves it elsewhere.
# BUKAGU_API_RECIPIENT_PATH=/recipient
